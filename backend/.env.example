# Application Settings
PROJECT_NAME="Automated Answer Script Evaluation Platform"
API_V1_STR="/api/v1"
DEBUG=True
ENVIRONMENT="development"

# CORS Origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://127.0.0.1:3000","http://127.0.0.1:5173"]

# Relational Database Configuration
DATABASE_URL="sqlite+aiosqlite:///./sql_app.db"

# MongoDB Configuration
MONGODB_URL="mongodb://localhost:27017"
MONGODB_DB_NAME="answer_script_evaluation"

# File Storage Settings
UPLOAD_DIR="uploads/answer_scripts"
MAX_UPLOAD_SIZE_MB=10

# Gemini AI Evaluation Settings
GEMINI_API_KEY="your_gemini_api_key_here"
GEMINI_MODEL="gemini-2.5-flash"

# Security
SECRET_KEY="development_secret_key_change_in_production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60
